<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Phiếu khám của tôi"
            android:textColor="@color/on_background"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/queueNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textColor="@color/primary"
            android:textSize="44sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleText" />

        <ImageView
            android:id="@+id/qrCodeImage"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="18dp"
            android:contentDescription="Mã QR phiếu khám"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/queueNumber" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/qrHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Đưa mã này cho nhân viên khi cần xác nhận phiếu"
            android:textColor="@color/on_background"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/qrCodeImage" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/finalStateMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/qrHint" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/nearTurnCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/near_turn_background"
            app:cardCornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/finalStateMessage">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Sắp đến lượt, vui lòng di chuyển gần phòng khám."
                android:textColor="@color/near_turn_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/detailsBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/nearTurnCard">

            <TextView android:id="@+id/patientName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="18sp" />
            <TextView android:id="@+id/patientPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/departmentName" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/roomNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/statusLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/estimatedWait" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/priorityReason" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/queuePosition" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/remainingBeforeMe" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/currentCallingNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
            <TextView android:id="@+id/updatedAt" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshStatusButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Làm mới trạng thái"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/detailsBlock" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/refreshProgress"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/refreshStatusButton" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/errorText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#B42318"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/refreshStatusButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backToDepartmentsButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:text="Quay lại danh sách khoa"
            android:textAllCaps="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/errorText" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
